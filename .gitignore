# ======================================
# 通用忽略项（所有项目必用）
# ======================================
# 日志文件
*.log
*.logs
logs/
# 临时/缓存文件
*.tmp
*.temp
*.swp
*.swo
*.bak
*~
# 构建输出目录
dist/
build/
out/
output/
# 环境变量/配置文件（敏感信息）
.env
.env.*
!.env.example  # 保留示例环境文件
# 证书/密钥文件
*.pem
*.key
*.crt
*.pub
# 压缩包
*.zip
*.rar
*.7z
*.tar
*.gz
*.bz2
# 数据库文件
*.db
*.sqlite
*.sqlite3
*.sql

# ======================================
# 操作系统专属忽略
# ======================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
Thumbs.db:encryptable
[Dd]esktop.ini
ehthumbs.db
# Linux
*~

# ======================================
# IDE / 编辑器专属忽略
# ======================================
# VS Code
.vscode/
*.code-workspace
# IntelliJ IDEA / PyCharm / Goland
.idea/
*.iml
*.iws
*.ipr
# Eclipse
.project
.classpath
.metadata/
# Visual Studio
.vs/
*.suo
# Sublime Text
*.sublime-workspace
# Vim
.*.sw?

# ======================================
# 编程语言 & 框架专属忽略
# ======================================
# 1. Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.tox/
.coverage
.pytest_cache/
.mypy_cache/
# 2. Node.js / JavaScript / 前端(React/Vue/Next)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
.nuxt/
.parcel-cache/
# 3. Java / Kotlin / Maven / Gradle
*.class
*.jar
*.war
target/
.gradle/
!gradle/wrapper/gradle-wrapper.jar
# 4. Go
/bin/
/vendor/
*.exe
*.dll
*.so
# 5. PHP
vendor/
composer.lock
.php-cs-fixer.cache
# 6. C# / .NET
[Bb]in/
[Oo]bj/
# 7. Ruby
/vendor/bundle
.bundle/
Gemfile.lock

# ======================================

